<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="3dp"
    app:cardBackgroundColor="#FFFFFF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="18dp">

        <!-- Top Row: Icon + Name + Delete -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="14dp">

            <!-- Icon circle -->
            <View
                android:id="@+id/goalIconCircle"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:background="#E8F4FF"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent" />

            <!-- We use a TextView as emoji icon -->
            <TextView
                android:id="@+id/tvGoalIcon"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:text="🎯"
                android:textSize="20sp"
                android:gravity="center"
                app:layout_constraintTop_toTopOf="@id/goalIconCircle"
                app:layout_constraintBottom_toBottomOf="@id/goalIconCircle"
                app:layout_constraintStart_toStartOf="@id/goalIconCircle"
                app:layout_constraintEnd_toEndOf="@id/goalIconCircle" />

            <!-- Goal Name -->
            <TextView
                android:id="@+id/tvGoalName"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="Holiday Fund"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="#003B5C"
                android:layout_marginStart="12dp"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toTopOf="@id/tvGoalSubtitle"
                app:layout_constraintStart_toEndOf="@id/tvGoalIcon"
                app:layout_constraintEnd_toStartOf="@id/btnDeleteGoal" />

            <!-- Subtitle: percent done -->
            <TextView
                android:id="@+id/tvGoalSubtitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="42% complete"
                android:textSize="12sp"
                android:textColor="#7A8FA6"
                android:layout_marginStart="12dp"
                app:layout_constraintTop_toBottomOf="@id/tvGoalName"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toEndOf="@id/tvGoalIcon"
                app:layout_constraintEnd_toStartOf="@id/btnDeleteGoal" />

            <!-- Delete -->
            <ImageButton
                android:id="@+id/btnDeleteGoal"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="@android:color/transparent"
                android:contentDescription="Delete goal"
                android:src="@android:drawable/ic_menu_delete"
                app:tint="#B0BEC5"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                tools:ignore="UseAppTint" />

        </androidx.constraintlayout.widget.ConstraintLayout>

        <!-- Progress Bar -->
        <ProgressBar
            android:id="@+id/pbGoalProgress"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="10dp"
            android:max="100"
            android:progress="42"
            android:progressTint="#00C8AA"
            android:progressBackgroundTint="#E8F4FF"
            android:layout_marginBottom="12dp" />

        <!-- Amount Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="12dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvGoalSaved"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="R 4,200"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#003B5C" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Saved"
                    android:textSize="11sp"
                    android:textColor="#7A8FA6" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">

                <TextView
                    android:id="@+id/tvGoalRemaining"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="R 5,800"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#FF6B35" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Remaining"
                    android:textSize="11sp"
                    android:textColor="#7A8FA6" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="end">

                <TextView
                    android:id="@+id/tvGoalTarget"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="R 10,000"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#7A8FA6" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Target"
                    android:textSize="11sp"
                    android:textColor="#7A8FA6" />
            </LinearLayout>
        </LinearLayout>

        <!-- Contribute Button -->
        <Button
            android:id="@+id/btnContribute"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:backgroundTint="#E8F4FF"
            android:text="+ Add Contribution"
            android:textColor="#003B5C"
            android:textSize="13sp"
            android:textStyle="bold"
            app:cornerRadius="8dp" />

    </LinearLayout>
</androidx.cardview.widget.CardView>
