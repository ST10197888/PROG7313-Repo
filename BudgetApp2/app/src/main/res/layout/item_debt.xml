<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="3dp"
    app:cardBackgroundColor="#FFFFFF">

    <!-- Left accent bar -->
    <View
        android:id="@+id/debtAccentBar"
        android:layout_width="5dp"
        android:layout_height="match_parent"
        android:background="#FF6B35" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="22dp"
        android:paddingEnd="18dp"
        android:paddingTop="18dp"
        android:paddingBottom="18dp">

        <!-- Top Row: Name + Status chip + Delete -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="14dp">

            <TextView
                android:id="@+id/tvDebtName"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="Car Loan"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#003B5C"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toStartOf="@id/tvDebtStatus" />

            <TextView
                android:id="@+id/tvDebtStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="In Progress"
                android:textSize="10sp"
                android:textStyle="bold"
                android:textColor="#FF6B35"
                android:background="#FFF0E8"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:paddingTop="3dp"
                android:paddingBottom="3dp"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintEnd_toStartOf="@id/btnDeleteDebt"
                android:layout_marginEnd="8dp" />

            <ImageButton
                android:id="@+id/btnDeleteDebt"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@android:drawable/ic_menu_delete"
                android:background="@android:color/transparent"
                android:contentDescription="Delete debt"
                android:tint="#B0BEC5"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

        </androidx.constraintlayout.widget.ConstraintLayout>

        <!-- Progress bar: paid / total -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="REPAYMENT PROGRESS"
            android:textSize="10sp"
            android:textStyle="bold"
            android:textColor="#7A8FA6"
            android:letterSpacing="0.08"
            android:layout_marginBottom="6dp" />

        <ProgressBar
            android:id="@+id/pbDebtProgress"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="10dp"
            android:max="100"
            android:progress="35"
            android:progressTint="#00C8AA"
            android:progressBackgroundTint="#FFE8E0"
            android:layout_marginBottom="12dp" />

        <!-- Amounts Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="14dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvDebtPaid"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="R 35,000"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="#00C8AA" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Paid"
                    android:textSize="11sp"
                    android:textColor="#7A8FA6" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">

                <TextView
                    android:id="@+id/tvDebtOutstanding"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="R 65,000"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="#FF6B35" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Outstanding"
                    android:textSize="11sp"
                    android:textColor="#7A8FA6" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="end">

                <TextView
                    android:id="@+id/tvDebtTotal"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="R 100,000"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="#7A8FA6" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Total"
                    android:textSize="11sp"
                    android:textColor="#7A8FA6" />
            </LinearLayout>

        </LinearLayout>

        <!-- Instalment + Record Payment -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvDebtInstalment"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="R 3,500 / month"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="#003B5C" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Monthly instalment"
                    android:textSize="11sp"
                    android:textColor="#7A8FA6" />
            </LinearLayout>

            <Button
                android:id="@+id/btnRecordPayment"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:text="Record Payment"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:backgroundTint="#003B5C"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                app:cornerRadius="8dp" />

        </LinearLayout>

    </LinearLayout>
</androidx.cardview.widget.CardView>
