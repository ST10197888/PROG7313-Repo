<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    app:cardCornerRadius="14dp"
    app:cardElevation="2dp"
    app:cardBackgroundColor="#FFFFFF">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp">

        <!-- Tip Number Badge -->
        <TextView
            android:id="@+id/tvTipNumber"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:text="1"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:background="#003B5C"
            android:gravity="center"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent" />

        <!-- Tip Category Tag -->
        <TextView
            android:id="@+id/tvTipCategory"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Saving"
            android:textSize="10sp"
            android:textStyle="bold"
            android:textColor="#00856E"
            android:background="#E0F7F4"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:paddingTop="3dp"
            android:paddingBottom="3dp"
            android:layout_marginStart="10dp"
            app:layout_constraintTop_toTopOf="@id/tvTipNumber"
            app:layout_constraintBottom_toTopOf="@id/tvTipText"
            app:layout_constraintStart_toEndOf="@id/tvTipNumber"
            app:layout_constraintEnd_toStartOf="@id/ivBookmark" />

        <!-- Bookmark toggle -->
        <ImageView
            android:id="@+id/ivBookmark"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@android:drawable/btn_star_big_off"
            android:contentDescription="Bookmark tip"
            android:tint="#B0BEC5"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Tip Text -->
        <TextView
            android:id="@+id/tvTipText"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Pay yourself first — automate a savings transfer on the day you receive your salary so you never spend what you intended to save."
            android:textSize="14sp"
            android:textColor="#2C3E50"
            android:lineSpacingMultiplier="1.4"
            android:layout_marginTop="10dp"
            app:layout_constraintTop_toBottomOf="@id/tvTipNumber"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Divider -->
        <View
            android:id="@+id/tipDivider"
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:background="#F0F4F8"
            android:layout_marginTop="12dp"
            app:layout_constraintTop_toBottomOf="@id/tvTipText"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Read More + Share row -->
        <TextView
            android:id="@+id/tvReadMore"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Read more"
            android:textSize="12sp"
            android:textStyle="bold"
            android:textColor="#003B5C"
            android:layout_marginTop="10dp"
            app:layout_constraintTop_toBottomOf="@id/tipDivider"
            app:layout_constraintStart_toStartOf="parent" />

        <TextView
            android:id="@+id/tvShareTip"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Share"
            android:textSize="12sp"
            android:textStyle="bold"
            android:textColor="#7A8FA6"
            android:layout_marginTop="10dp"
            app:layout_constraintTop_toBottomOf="@id/tipDivider"
            app:layout_constraintEnd_toEndOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.cardview.widget.CardView>
