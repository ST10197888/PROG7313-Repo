<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/scrollViewProfile"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_grey">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Avatar card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="@color/profile_card_bg">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp"
                android:gravity="center">

                <TextView
                    android:layout_width="72dp"
                    android:layout_height="72dp"
                    android:text="👤"
                    android:textSize="40sp"
                    android:gravity="center"
                    android:background="@color/profile_avatar_circle_bg"
                    android:layout_marginBottom="12dp" />

                <TextView
                    android:id="@+id/tvProfileName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Name"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="@color/header_on_background" />

                <TextView
                    android:id="@+id/tvProfileEmail"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="email@example.com"
                    android:textSize="14sp"
                    android:textColor="#CCFFFFFF"
                    android:layout_marginTop="4dp" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ENHANCED Financial Fitness Card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="@color/card_background">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Financial Fitness Score"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary"
                    android:layout_marginBottom="12dp" />

                <ProgressBar
                    android:id="@+id/pbProfileFitness"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="match_parent"
                    android:layout_height="12dp"
                    android:progress="0"
                    android:max="100"
                    android:progressTint="@color/colorPrimary"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:id="@+id/tvProfileFitnessScore"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Total Score: 0%"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="@color/colorPrimary" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#EEE"
                    android:layout_marginVertical="12dp" />

                <!-- Component 1: Surplus -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="4dp">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:text="Budget Discipline (Income vs Expense)"
                        android:textSize="12sp"
                        android:textColor="@color/text_secondary" />
                    <TextView
                        android:id="@+id/tvFitnessSurplusScore"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0/70"
                        android:textSize="12sp"
                        android:textStyle="bold" />
                </LinearLayout>
                <ProgressBar
                    android:id="@+id/pbFitnessSurplus"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="match_parent"
                    android:layout_height="4dp"
                    android:progress="0"
                    android:max="70"
                    android:progressTint="@color/income_green"
                    android:layout_marginBottom="12dp" />

                <!-- Component 2: Savings -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="4dp">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:text="Savings Momentum (Target 20%)"
                        android:textSize="12sp"
                        android:textColor="@color/text_secondary" />
                    <TextView
                        android:id="@+id/tvFitnessSavingsScore"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0/30"
                        android:textSize="12sp"
                        android:textStyle="bold" />
                </LinearLayout>
                <ProgressBar
                    android:id="@+id/pbFitnessSavings"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="match_parent"
                    android:layout_height="4dp"
                    android:progress="0"
                    android:max="30"
                    android:progressTint="@color/colorPrimary" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- COMBINED Stats card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="@color/card_background">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="My Financial Stats"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary"
                    android:layout_marginBottom="16dp" />

                <!-- Key Metrics -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="12dp">
                    <LinearLayout android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Transactions" android:textSize="11sp" android:textColor="@color/text_secondary"/>
                        <TextView android:id="@+id/tvTxCount" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0" android:textStyle="bold" android:textSize="15sp"/>
                    </LinearLayout>
                    <LinearLayout android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Savings Rate" android:textSize="11sp" android:textColor="@color/text_secondary"/>
                        <TextView android:id="@+id/tvSummarySavingsRate" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0%" android:textStyle="bold" android:textSize="15sp" android:textColor="@color/colorPrimary"/>
                    </LinearLayout>
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#F0F0F0" android:layout_marginBottom="16dp"/>

                <!-- Detailed Totals -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="8dp">
                    <TextView android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:text="Total Income" android:textSize="14sp" android:textColor="@color/text_secondary"/>
                    <TextView android:id="@+id/tvSummaryIncome" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="R 0.00" android:textStyle="bold" android:textColor="@color/income_green"/>
                </LinearLayout>

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="8dp">
                    <TextView android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:text="Total Expenses" android:textSize="14sp" android:textColor="@color/text_secondary"/>
                    <TextView android:id="@+id/tvSummaryExpenses" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="R 0.00" android:textStyle="bold" android:textColor="@color/expense_red"/>
                </LinearLayout>

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="8dp">
                    <TextView android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:text="Total Savings" android:textSize="14sp" android:textColor="@color/text_secondary"/>
                    <TextView android:id="@+id/tvSummarySavings" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="R 0.00" android:textStyle="bold" android:textColor="@color/colorPrimary"/>
                </LinearLayout>

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="8dp">
                    <TextView android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:text="Debt Balance" android:textSize="14sp" android:textColor="@color/text_secondary"/>
                    <TextView android:id="@+id/tvTotalDebt" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="R 0.00" android:textStyle="bold" android:textColor="#E65100"/>
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#F0F0F0" android:layout_marginVertical="12dp"/>

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
                    <TextView android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:text="Available Balance" android:textStyle="bold" android:textColor="@color/text_primary"/>
                    <TextView android:id="@+id/tvTotalSaved" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="R 0.00" android:textStyle="bold" android:textColor="@color/income_green" android:textSize="16sp"/>
                </LinearLayout>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Usage Card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="@color/card_background">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Usage Distribution"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary"
                    android:layout_marginBottom="12dp" />

                <!-- Total Amount -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="bottom">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:text="Total cash handled"
                        android:textSize="13sp"
                        android:textColor="@color/text_secondary" />
                    <TextView
                        android:id="@+id/tvUsageTotalAmount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="R 0.00"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:textColor="@color/income_green" />
                </LinearLayout>
                <ProgressBar
                    android:id="@+id/pbUsageTotal"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="match_parent"
                    android:layout_height="8dp"
                    android:progress="100"
                    android:progressTint="@color/income_green"
                    android:layout_marginTop="4dp"
                    android:layout_marginBottom="12dp" />

                <!-- Income -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:text="Income"
                        android:textSize="12sp"
                        android:textColor="@color/text_secondary" />
                    <TextView
                        android:id="@+id/tvUsageIncomePercent"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0%"
                        android:textSize="12sp"
                        android:textColor="@color/text_primary" />
                </LinearLayout>
                <ProgressBar
                    android:id="@+id/pbUsageIncome"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="match_parent"
                    android:layout_height="4dp"
                    android:progress="0"
                    android:progressTint="@color/income_green"
                    android:layout_marginTop="2dp"
                    android:layout_marginBottom="8dp" />

                <!-- Expense -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:text="Expense"
                        android:textSize="12sp"
                        android:textColor="@color/text_secondary" />
                    <TextView
                        android:id="@+id/tvUsageExpensePercent"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0%"
                        android:textSize="12sp"
                        android:textColor="@color/text_primary" />
                </LinearLayout>
                <ProgressBar
                    android:id="@+id/pbUsageExpense"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="match_parent"
                    android:layout_height="4dp"
                    android:progress="0"
                    android:progressTint="@color/expense_red"
                    android:layout_marginTop="2dp"
                    android:layout_marginBottom="8dp" />

                <!-- Savings -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:text="Savings"
                        android:textSize="12sp"
                        android:textColor="@color/text_secondary" />
                    <TextView
                        android:id="@+id/tvUsageSavingsPercent"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0%"
                        android:textSize="12sp"
                        android:textColor="@color/text_primary" />
                </LinearLayout>
                <ProgressBar
                    android:id="@+id/pbUsageSavings"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="match_parent"
                    android:layout_height="4dp"
                    android:progress="0"
                    android:progressTint="@color/colorPrimary"
                    android:layout_marginTop="2dp"
                    android:layout_marginBottom="8dp" />

                <!-- Debt -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:text="Debt"
                        android:textSize="12sp"
                        android:textColor="@color/text_secondary" />
                    <TextView
                        android:id="@+id/tvUsageDebtPercent"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0%"
                        android:textSize="12sp"
                        android:textColor="@color/text_primary" />
                </LinearLayout>
                <ProgressBar
                    android:id="@+id/pbUsageDebt"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="match_parent"
                    android:layout_height="4dp"
                    android:progress="0"
                    android:progressTint="#FF9800"
                    android:layout_marginTop="2dp" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Badges Card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="@color/card_background">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Unlocked Badges"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary"
                    android:layout_marginBottom="12dp" />

                <LinearLayout
                    android:id="@+id/layoutProfileBadges"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Settings Button -->
        <Button
            android:id="@+id/btnProfileSettings"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="Settings"
            android:layout_marginBottom="12dp"
            android:backgroundTint="@color/colorPrimary"
            android:textColor="@color/white"
            android:textSize="16sp" />

        <!-- Logout -->
        <Button
            android:id="@+id/btnLogout"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="Log Out"
            android:backgroundTint="#F44336"
            android:textColor="@color/white"
            android:textSize="16sp" />

    </LinearLayout>
</ScrollView>
